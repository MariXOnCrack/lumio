# Optional initial Jellyfin server URL.
# If this is empty, Lumio shows a first-launch setup page.
# If Jellyfin is in the same compose network and its service is named jellyfin:
# JELLYFIN_SERVER_URL=http://jellyfin:8096
JELLYFIN_SERVER_URL=

# Public host port for Lumio's web UI.
LUMIO_HOST_PORT=37891

LUMIO_PORT=3000
